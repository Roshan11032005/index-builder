# ─────────────────────────────
# S3 / MinIO Configuration
# ─────────────────────────────

S3_ENDPOINT=http://host.docker.internal:9100
# RocksDB Shards
SHARD_URLS=host.docker.internal:9002,host.docker.internal:9012,host.docker.internal:9022,host.docker.internal:9032,host.docker.internal:9042

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
# index-builder .env — add this line
KAFKA_BROKERS=host.docker.internal:9092

# shard used for cursor persistence
CURSOR_SHARD_IDX=0


# ─────────────────────────────
# Compaction Settings
# ─────────────────────────────

COMPACTION_DELTA_LIMIT=50
COMPACTION_MAX_AGE=24h


# ─────────────────────────────
# Processing
# ─────────────────────────────

POLL_INTERVAL=10s
SST_TEMP_DIR=./tmp/sst


# ─────────────────────────────
# HTTP Server
# ─────────────────────────────

HTTP_PORT=8086